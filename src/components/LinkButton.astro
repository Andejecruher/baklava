---
interface Props {
  label: string;
  href: string;
  variant?: "default" | "primary" | "ghost";
  icon?: string;
  external?: boolean;
  sublabel?: string;
  ariaLabel?: string;
}
const {
  label,
  href,
  variant = "default",
  icon,
  external,
  sublabel,
  ariaLabel,
} = Astro.props;

const target = external ? "_blank" : undefined;
const rel    = external ? "noopener noreferrer" : undefined;
const computedAriaLabel = ariaLabel ?? (sublabel ? `${label} — ${sublabel}` : label);
---

<a
  href={href}
  target={target}
  rel={rel}
  class={`link-btn link-${variant}`}
  aria-label={computedAriaLabel}
  role="link"
>
  {icon && (
    <span class="icon" set:html={icon} aria-hidden="true" />
  )}
  <span class="labels">
    <span class="label">{label}</span>
    {sublabel && <span class="sub">{sublabel}</span>}
  </span>
  <svg
    class="chev"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="m9 18 6-6-6-6"/>
  </svg>
</a>

<style>
  .link-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 15px 18px;
    min-height: 60px;       /* touch-friendly: ≥44px */
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(7,59,76,0.08);
    border-radius: 14px;
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--duration-base) var(--ease-out-expo),
      box-shadow var(--duration-base) ease,
      border-color var(--duration-base) ease,
      background var(--duration-base) ease;
    cursor: pointer;
  }
  .link-btn:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: rgba(25,184,198,0.35);
    background: rgba(255,255,255,0.98);
  }
  .link-btn:active { transform: translateY(-1px); }

  .icon {
    width: 42px; height: 42px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(25,184,198,0.14), rgba(184,232,223,0.38));
    color: var(--c-turquoise);
    border-radius: 12px;
    transition: background var(--duration-base) ease;
  }
  .link-btn:hover .icon {
    background: linear-gradient(135deg, rgba(25,184,198,0.22), rgba(184,232,223,0.55));
  }

  .labels {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .label  { font-weight: 600; color: var(--c-deep); font-size: 15px; }
  .sub    { font-size: 12.5px; color: var(--c-muted); }
  .chev   { color: var(--c-turquoise); flex-shrink: 0; transition: transform var(--duration-base) ease; }
  .link-btn:hover .chev { transform: translateX(3px); }

  /* Primary variant */
  .link-primary {
    background: linear-gradient(135deg, var(--c-turquoise), var(--c-turquoise-dk));
    border: none;
  }
  .link-primary:hover {
    background: linear-gradient(135deg, #22c8d8, var(--c-turquoise));
    border: none;
  }
  .link-primary .label,
  .link-primary .chev    { color: var(--c-white); }
  .link-primary .sub     { color: rgba(255,255,255,0.85); }
  .link-primary .icon    { background: rgba(255,255,255,0.2); color: var(--c-white); }
  .link-primary:hover .icon { background: rgba(255,255,255,0.28); }

  /* Ghost variant */
  .link-ghost {
    background: transparent;
    box-shadow: none;
  }
  .link-ghost:hover {
    background: rgba(25,184,198,0.06);
    border-color: rgba(25,184,198,0.25);
  }
</style>
