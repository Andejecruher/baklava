---
interface Props {
  label: string;
  href: string;
  variant?: "default" | "primary" | "ghost";
  icon?: string;
  external?: boolean;
  sublabel?: string;
}
const { label, href, variant = "default", icon, external, sublabel } = Astro.props;
const target = external ? "_blank" : undefined;
const rel = external ? "noopener noreferrer" : undefined;
---

<a href={href} target={target} rel={rel} class={`link-btn link-${variant}`}>
  {icon && <span class="icon" set:html={icon} />}
  <span class="labels">
    <span class="label">{label}</span>
    {sublabel && <span class="sub">{sublabel}</span>}
  </span>
  <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
</a>

<style>
  .link-btn {
    display: flex; align-items: center; gap: 14px;
    padding: 15px 18px;
    background: var(--white);
    border: 1px solid rgba(6,59,91,0.08);
    border-radius: 14px;
    box-shadow: var(--shadow-sm);
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  .link-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: rgba(16,184,196,0.35); }
  .link-btn:active { transform: translateY(0); }
  .icon {
    width: 40px; height: 40px; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, rgba(16,184,196,0.15), rgba(189,234,217,0.4));
    color: var(--turquoise); border-radius: 12px;
  }
  .labels { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .label { font-weight: 600; color: var(--deep); font-size: 15px; }
  .sub { font-size: 12.5px; color: var(--muted); }
  .chev { color: var(--turquoise); flex-shrink: 0; }

  .link-primary { background: linear-gradient(135deg, var(--turquoise), #0a8d97); border: none; }
  .link-primary .label, .link-primary .chev { color: var(--white); }
  .link-primary .sub { color: rgba(255,255,255,0.85); }
  .link-primary .icon { background: rgba(255,255,255,0.2); color: var(--white); }
</style>
