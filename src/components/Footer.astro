---
interface Props { name: string; logo: string; }
const { name, logo } = Astro.props;
---

<footer class="foot">
  <img src={logo} alt={name} />
  <p class="brand">{name}</p>
  <p class="tagline">Experiencias frescas frente al mar.</p>
  <p class="note">Promociones sujetas a disponibilidad.</p>
  <p class="copy">© {new Date().getFullYear()} Baklava Club de Mar</p>
</footer>

<style>
  .foot {
    margin-top: 56px;
    text-align: center;
    padding: 28px 16px 8px;
    border-top: 1px solid rgba(6,59,91,0.08);
  }
  img { width: 140px; height: auto; opacity: 0.85; margin-bottom: 10px; }
  .brand { margin: 4px 0 0; font-family: var(--font-display); font-weight: 600; color: var(--deep); font-size: 16px; }
  .tagline { margin: 6px 0 0; color: var(--turquoise); font-size: 13px; font-style: italic; }
  .note { margin: 14px 0 0; color: var(--muted); font-size: 11.5px; }
  .copy { margin: 8px 0 0; color: var(--muted); font-size: 11px; opacity: 0.7; }
</style>
