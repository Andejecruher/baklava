---
/**
 * LandingPage — shared composition for all locale pages.
 * Receives the locale and the translation object; renders the full landing.
 */
import FloatingWhatsAppButton from './FloatingWhatsAppButton.astro';
import Footer from './Footer.astro';
import Hero from './Hero.astro';
import Hours from './Hours.astro';
import LanguageSelector from './LanguageSelector.astro';
import LinkButton from './LinkButton.astro';
import LocationCard from './LocationCard.astro';
import Promotions from './Promotions.astro';
import SocialLinks from './SocialLinks.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { siteData } from '../data/site';
import { WHATSAPP_NUMBER } from '../data/config';
import type { Locale } from '../i18n/config';
import { LOCALE_OG } from '../i18n/config';
import type { Translations } from '../i18n/translations/index';

interface Props {
  locale: Locale;
  t: Translations;
}

const { locale, t } = Astro.props;
const { brand, links, social, seo } = siteData;

// Locale-aware WhatsApp URL
const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(t.whatsappMessage)}`;

const iconMenu = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16v4H4z"/><path d="M4 12h16"/><path d="M4 18h10"/></svg>`;
const iconWa   = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.554 4.122 1.523 5.855L.057 23.882a.5.5 0 0 0 .617.617l6.085-1.476A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.655-.497-5.189-1.367l-.371-.214-3.854.935.952-3.78-.228-.385A9.952 9.952 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>`;
const iconMap  = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21 3 6"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg>`;
const iconIg   = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`;
const iconFb   = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`;
const iconPromo = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" x2="7.01" y1="7" y2="7"/></svg>`;

const canonical = locale === 'es'
  ? `${seo.siteUrl}/`
  : `${seo.siteUrl}/${locale}`;
---

<MainLayout
  title={t.seoTitle}
  description={t.seoDescription}
  canonical={canonical}
  image={seo.image}
  type="website"
  locale={LOCALE_OG[locale]}
  breadcrumbHome={t.breadcrumbHome}
  currentLocale={locale}
>
  <!-- Skip to main content -->
  <a class="skip-link" href="#main-links">{t.skipToMain}</a>

  <!-- Language selector — top of page -->
  <LanguageSelector currentLocale={locale} label={t.langSelector} />

  <Hero
    name={brand.name}
    subtitle={t.brandSubtitle}
    description={t.brandDescription}
    logo={brand.logo}
    menuHref={links.menu}
    whatsappHref={whatsappUrl}
    eyebrow={t.heroEyebrow}
    ctaMenu={t.ctaMenu}
    ctaWhatsapp={t.ctaWhatsapp}
  />

  <section class="section" aria-labelledby="links-title" id="main-links">
    <h2 class="section-title" id="links-title">{t.linksTitle}</h2>
    <nav class="links" aria-label={t.ariaMainLinks}>
      <div class="anim-fade-up stagger-1">
        <LinkButton
          label={t.linkMenu}
          sublabel={t.linkMenuSub}
          href={links.menu}
          variant="primary"
          icon={iconMenu}
          ariaLabel={t.linkMenu}
        />
      </div>
      <div class="anim-fade-up stagger-2">
        <LinkButton
          label={t.linkWhatsapp}
          sublabel={t.linkWhatsappSub}
          href={whatsappUrl}
          icon={iconWa}
          external
          ariaLabel={t.linkWhatsapp}
        />
      </div>
      <div class="anim-fade-up stagger-3">
        <LinkButton
          label={t.linkMaps}
          sublabel={t.linkMapsSub}
          href={links.maps}
          icon={iconMap}
          external
          ariaLabel={t.linkMaps}
        />
      </div>
      <div class="anim-fade-up stagger-4">
        <LinkButton
          label={t.linkPromos}
          sublabel={t.linkPromosSub}
          href="#promociones"
          icon={iconPromo}
          ariaLabel={t.linkPromos}
        />
      </div>
      <div class="anim-fade-up stagger-5">
        <LinkButton
          label="Instagram"
          sublabel={social.instagramHandle}
          href={links.instagram}
          icon={iconIg}
          external
          ariaLabel={`Instagram — ${social.instagramHandle}`}
        />
      </div>
      <div class="anim-fade-up stagger-6">
        <LinkButton
          label="Facebook"
          sublabel={social.facebookName}
          href={links.facebook}
          icon={iconFb}
          external
          ariaLabel={`Facebook — ${social.facebookName}`}
        />
      </div>
    </nav>
  </section>

  <Promotions promotions={t.promos} title={t.promosTitle} />
  <Hours hours={t.hours} title={t.hoursTitle} ariaLabel={t.ariaOpeningHours} />
  <LocationCard
    location={brand.location}
    mapsHref={links.maps}
    title={t.locationTitle}
    nearSeaLabel={t.locationNearSea}
    openMapsLabel={t.locationOpenMaps}
  />
  <SocialLinks
    instagramHref={links.instagram}
    instagramHandle={social.instagramHandle}
    facebookHref={links.facebook}
    facebookName={social.facebookName}
    title={t.followTitle}
  />
  <Footer
    name={brand.name}
    logo={brand.logo}
    tagline={t.footerTagline}
    promoNote={t.footerPromoNote}
    rights={t.footerRights}
  />

  <FloatingWhatsAppButton href={whatsappUrl} label={t.waButtonAriaLabel} />
</MainLayout>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 8px;
    z-index: 9999;
    background: var(--c-turquoise);
    color: var(--c-white);
    padding: 10px 18px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
  }
  .skip-link:focus {
    left: 16px;
    outline: 3px solid var(--c-deep);
    outline-offset: 2px;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
</style>
