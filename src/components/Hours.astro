---
import type { HoursEntry } from "../data/site";
interface Props { hours: HoursEntry[]; }
const { hours } = Astro.props;
---

<section class="section">
  <h2 class="section-title">Horarios</h2>
  <div class="card hours">
    <div class="icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <ul>
      {hours.map((h) => (
        <li>
          <span class="day">{h.day}</span>
          <span class="time">{h.time}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hours { padding: 20px; display: flex; gap: 16px; align-items: flex-start; }
  .icon {
    width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
    background: linear-gradient(135deg, rgba(16,184,196,0.15), rgba(189,234,217,0.4));
    color: var(--turquoise);
    display: inline-flex; align-items: center; justify-content: center;
  }
  ul { list-style: none; margin: 0; padding: 0; flex: 1; }
  li { display: flex; flex-direction: column; gap: 2px; padding: 4px 0; }
  .day { font-weight: 600; color: var(--deep); font-size: 15px; }
  .time { color: var(--muted); font-size: 13.5px; }
</style>
