---
import type { Promotion } from "../data/site";
interface Props { promotions: Promotion[]; }
const { promotions } = Astro.props;
---

<section class="section" id="promociones">
  <h2 class="section-title">Promos del día</h2>
  <div class="promo-grid">
    {promotions.map((p) => (
      <article class="promo card">
        <div class="badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          2x1
        </div>
        <h3>{p.title}</h3>
        <p class="time">{p.description}</p>
        {p.note && <p class="note">{p.note}</p>}
      </article>
    ))}
  </div>
</section>

<style>
  .promo-grid { display: flex; flex-direction: column; gap: 14px; }
  .promo { padding: 22px 20px; position: relative; overflow: hidden; }
  .promo::before {
    content: ""; position: absolute; top: 0; left: 0; width: 4px; height: 100%;
    background: linear-gradient(180deg, var(--turquoise), var(--turquoise-soft));
  }
  .badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
    color: var(--turquoise);
    background: rgba(16,184,196,0.10);
    padding: 5px 10px; border-radius: 999px;
    margin-bottom: 10px;
  }
  h3 { font-size: 19px; font-weight: 600; color: var(--deep); }
  .time { margin: 6px 0 0; color: var(--navy); font-size: 14px; font-weight: 500; }
  .note { margin: 10px 0 0; color: var(--muted); font-size: 12.5px; font-style: italic; }
</style>
