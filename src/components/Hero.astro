---
interface Props {
  name: string;
  subtitle: string;
  description: string;
  logo: string;
  menuHref: string;
  whatsappHref: string;
  eyebrow?: string;
  ctaMenu?: string;
  ctaWhatsapp?: string;
}
const {
  name,
  subtitle,
  description,
  logo,
  menuHref,
  whatsappHref,
  eyebrow = '',
  ctaMenu = '',
  ctaWhatsapp = '',
} = Astro.props;
---

<section class="hero anim-fade-up" aria-label={name}>
  <div class="hero-card">
    <span class="eyebrow">{eyebrow}</span>

    <div class="logo-wrap" role="img" aria-label={name}>
      <img src={logo} alt={name} width="200" height="72" loading="eager" />
    </div>

    <h1>{name}</h1>
    <p class="subtitle" aria-label={subtitle}>{subtitle}</p>
    <p class="desc">{description}</p>

    <div class="cta" role="group" aria-label={ctaMenu}>
      <a
        class="btn btn-primary"
        href={menuHref}
        aria-label={ctaMenu}
      >
        <svg
          width="20" height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 4h16v4H4z"/>
          <path d="M4 12h16"/>
          <path d="M4 18h10"/>
        </svg>
        <span>{ctaMenu}</span>
        <svg
          class="arrow"
          width="18" height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>

      <a
        class="btn btn-whatsapp"
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={ctaWhatsapp}
      >
        <svg
          width="20" height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.554 4.122 1.523 5.855L.057 23.882a.5.5 0 0 0 .617.617l6.085-1.476A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.655-.497-5.189-1.367l-.371-.214-3.854.935.952-3.78-.228-.385A9.952 9.952 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
        </svg>
        <span>{ctaWhatsapp}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero { padding-top: 8px; }

  .hero-card {
    text-align: center;
    padding: 40px 24px 36px;
    border-radius: 28px;
    background:
      linear-gradient(160deg, rgba(255,255,255,0.94), rgba(255,255,255,0.80)),
      radial-gradient(600px 300px at 50% -10%, rgba(25,184,198,0.28), transparent 70%);
    border: 1px solid rgba(255,255,255,0.82);
    box-shadow: var(--shadow-lg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .logo-wrap {
    width: 200px;
    height: 72px;
    margin: 20px auto 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  h1 {
    font-size: clamp(26px, 6vw, 34px);
    font-weight: 700;
    color: var(--c-deep);
    line-height: 1.1;
  }

  .subtitle {
    margin: 10px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--c-turquoise);
    font-size: 17px;
  }

  .desc {
    margin: 14px auto 0;
    max-width: 380px;
    color: var(--c-muted);
    font-size: 14.5px;
    line-height: 1.6;
  }

  .cta {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 22px;
    border-radius: 14px;
    font-weight: 600;
    font-size: 15.5px;
    min-height: 52px;        /* touch-friendly */
    width: 100%;
    transition:
      transform var(--duration-base) var(--ease-out-expo),
      box-shadow var(--duration-base) ease,
      background var(--duration-base) ease;
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--c-turquoise), var(--c-turquoise-dk));
    color: var(--c-white);
    box-shadow: 0 10px 28px rgba(25,184,198,0.38);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(25,184,198,0.48);
  }
  .btn-primary:active { transform: translateY(0); }
  .btn-primary .arrow {
    transition: transform var(--duration-base) ease;
  }
  .btn-primary:hover .arrow { transform: translateX(4px); }

  .btn-whatsapp {
    background: var(--c-whatsapp);
    color: var(--c-white);
    box-shadow: 0 10px 28px rgba(37,211,102,0.30);
  }
  .btn-whatsapp:hover {
    background: var(--c-whatsapp-dk);
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(37,211,102,0.40);
  }
  .btn-whatsapp:active { transform: translateY(0); }
</style>
