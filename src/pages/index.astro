---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Hours from '../components/Hours.astro';
import LinkButton from '../components/LinkButton.astro';
import LocationCard from '../components/LocationCard.astro';
import Promotions from '../components/Promotions.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { siteData } from '../data/site';
import MainLayout from '../layouts/MainLayout.astro';

const { brand, links, promotions, hours, social, seo } = siteData;

const iconMenu = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v4H4z"/><path d="M4 12h16"/><path d="M4 18h10"/></svg>`;
const iconWa = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`;
const iconMap = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21 3 6"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg>`;
const iconIg = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`;
const iconFb = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`;
const iconPromo = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" x2="7.01" y1="7" y2="7"/></svg>`;
const iconEvent = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>`;
---

<MainLayout
  title={seo.defaultTitle}
  description={seo.defaultDescription}
  canonical={`${seo.siteUrl}/`}
  image={seo.image}
  type="website"
>
  <Hero
    name={brand.name}
    subtitle={brand.subtitle}
    description={brand.description}
    logo={brand.logo}
    menuHref={links.menu}
    whatsappHref={links.whatsapp}
  />

  <section class="section">
    <h2 class="section-title">Todo Baklava en un solo lugar</h2>
    <div class="links">
      <LinkButton
        label="Ver menú"
        sublabel="Carta completa"
        href={links.menu}
        variant="primary"
        icon={iconMenu}
      />
      <LinkButton
        label="Reservar por WhatsApp"
        sublabel="Respuesta inmediata"
        href={links.whatsapp}
        icon={iconWa}
        external
      />
      <LinkButton
        label="Cómo llegar"
        sublabel="Abrir en Google Maps"
        href={links.maps}
        icon={iconMap}
        external
      />
      <LinkButton
        label="Promociones"
        sublabel="2x1 y especiales del día"
        href="#promociones"
        icon={iconPromo}
      />
      <!-- <LinkButton label="Eventos" sublabel="Música en vivo y más" href={links.events} icon={iconEvent} /> -->
      <LinkButton
        label="Instagram"
        sublabel={social.instagramHandle}
        href={links.instagram}
        icon={iconIg}
        external
      />
      <LinkButton
        label="Facebook"
        sublabel={social.facebookName}
        href={links.facebook}
        icon={iconFb}
        external
      />
    </div>
  </section>

  <Promotions promotions={promotions} />
  <Hours hours={hours} />
  <LocationCard location={brand.location} mapsHref={links.maps} />
  <SocialLinks
    instagramHref={links.instagram}
    instagramHandle={social.instagramHandle}
    facebookHref={links.facebook}
    facebookName={social.facebookName}
  />
  <Footer name={brand.name} logo={brand.logo} />
</MainLayout>

<style>
  .links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
</style>
